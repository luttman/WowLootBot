DISCORD_TOKEN=
CLIENT_ID=
GUILD_ID=
OWNER_ID=
# Your own Discord user ID. Only this account can run /admin-status.
# Enable Developer Mode in Discord, right click your own name, Copy User ID.
# DB_PATH=loot.db
# Only needed for running without Docker. Leave commented out when using
# docker-compose: the Dockerfile already points DB_PATH at the persisted
# volume, and setting it here would override that and lose your data on
# every rebuild.
